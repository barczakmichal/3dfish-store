# Production environment for docker-compose on VPS
# Copy to .env and fill in real values before running docker compose up

# PostgreSQL
DB_PASSWORD=generate-strong-password-here

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Admin panel
ADMIN_PASSWORD=your-secure-admin-password

# Stripe (replace with production keys when ready)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
