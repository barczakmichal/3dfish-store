# Database (PostgreSQL)
# Vercel Postgres: auto-ustawiane przez Vercel (POSTGRES_PRISMA_URL)
# Local: postgresql://paperclip:paperclip@localhost:54329/wedkarska_fabryka
# VPS: postgresql://user:password@host:5432/3dfish
DATABASE_URL="postgresql://user:password@localhost:5432/3dfish"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Admin panel
ADMIN_PASSWORD="your-secure-admin-password"

# App URL (required behind reverse proxy — used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL="https://treefish.pl"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Slack (powiadomienia o zamówieniach)
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/T.../B.../..."

# Furgonetka (wysyłka)
FURGONETKA_CLIENT_ID=""
FURGONETKA_CLIENT_SECRET=""
FURGONETKA_USERNAME=""
FURGONETKA_PASSWORD=""
FURGONETKA_SECRET_KEY=""
FURGONETKA_API_URL="https://api.sandbox.furgonetka.pl"
NEXT_PUBLIC_FURGONETKA_ENV="sandbox"

# Furgonetka Universal Integration (token generowany przez sklep)
FURGONETKA_INTEGRATION_TOKEN=""
# Furgonetka Koszyk (widget checkout UUID - pobierz z panelu Furgonetka → Integracje → Koszyk)
NEXT_PUBLIC_FURGONETKA_CHECKOUT_UUID=""

# Meta Pixel + Conversions API
NEXT_PUBLIC_META_PIXEL_ID=""
META_PIXEL_ID=""
META_CAPI_ACCESS_TOKEN=""
